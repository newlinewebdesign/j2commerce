<?xml version="1.0" encoding="utf-8"?>
<extension type="module" method="upgrade" client="site">
    <name>MOD_J2COMMERCE_CURRENCY</name>
    <creationDate>2026-02</creationDate>
    <author>J2Commerce, LLC</author>
    <copyright>(C)2024-2026 J2Commerce, LLC. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <authorEmail>support@j2commerce.com</authorEmail>
    <authorUrl>https://www.j2commerce.com</authorUrl>
    <version>6.0.7</version>
    <description>MOD_J2COMMERCE_CURRENCY_DESC</description>
    <namespace path="src">J2Commerce\Module\Currency</namespace>
    <files>
        <folder module="mod_j2commerce_currency">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>
    <languages folder="language">
        <language tag="en-GB">en-GB/mod_j2commerce_currency.ini</language>
        <language tag="en-GB">en-GB/mod_j2commerce_currency.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="background_color"
                    type="color"
                    default="#FFFFFF"
                    label="MOD_J2COMMERCE_CURRENCY_BACKGROUND_COLOR"
                    description="MOD_J2COMMERCE_CURRENCY_BACKGROUND_COLOR_DESC"
                />
                <field
                    name="text_color"
                    type="color"
                    default="#000000"
                    label="MOD_J2COMMERCE_CURRENCY_TEXT_COLOR"
                    description="MOD_J2COMMERCE_CURRENCY_TEXT_COLOR_DESC"
                />
                <field
                    name="link_color"
                    type="color"
                    default="#CCCCCC"
                    label="MOD_J2COMMERCE_CURRENCY_LINK_COLOR"
                    description="MOD_J2COMMERCE_CURRENCY_LINK_COLOR_DESC"
                />
                <field
                    name="link_hover_color"
                    type="color"
                    default="#000000"
                    label="MOD_J2COMMERCE_CURRENCY_LINK_HOVER_COLOR"
                    description="MOD_J2COMMERCE_CURRENCY_LINK_HOVER_COLOR_DESC"
                />
                <field
                    name="active_link_color"
                    type="color"
                    default="#000000"
                    label="MOD_J2COMMERCE_CURRENCY_ACTIVE_LINK_COLOR"
                    description="MOD_J2COMMERCE_CURRENCY_ACTIVE_LINK_COLOR_DESC"
                />
            </fieldset>
            <fieldset name="advanced">
                <field
                    name="layout"
                    type="modulelayout"
                    class="form-select"
                    label="JFIELD_ALT_LAYOUT_LABEL"
                />
                <field
                    name="moduleclass_sfx"
                    type="textarea"
                    rows="3"
                    label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                />
            </fieldset>
        </fields>
    </config>
</extension>
