<?xml version="1.0" encoding="utf-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_J2COMMERCE_PRODUCTS</name>
    <author>J2Commerce, LLC</author>
    <authorUrl>https://www.j2commerce.com</authorUrl>
    <copyright>(C)2024-2026 J2Commerce, LLC. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <version>6.0.7</version>
    <description>MOD_J2COMMERCE_PRODUCTS_DESC</description>
    <namespace path="src">J2Commerce\Module\Products</namespace>

    <files>
        <folder module="mod_j2commerce_products">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
        <folder>language</folder>
    </files>

    <languages folder="language">
        <language tag="en-US">en-US/mod_j2commerce_products.ini</language>
        <language tag="en-US">en-US/mod_j2commerce_products.sys.ini</language>
        <language tag="ar-AA">ar-AA/mod_j2commerce_products.ini</language>
        <language tag="ar-AA">ar-AA/mod_j2commerce_products.sys.ini</language>
        <language tag="da-DK">da-DK/mod_j2commerce_products.ini</language>
        <language tag="da-DK">da-DK/mod_j2commerce_products.sys.ini</language>
        <language tag="de-DE">de-DE/mod_j2commerce_products.ini</language>
        <language tag="de-DE">de-DE/mod_j2commerce_products.sys.ini</language>
        <language tag="el-GR">el-GR/mod_j2commerce_products.ini</language>
        <language tag="el-GR">el-GR/mod_j2commerce_products.sys.ini</language>
        <language tag="en-GB">en-GB/mod_j2commerce_products.ini</language>
        <language tag="en-GB">en-GB/mod_j2commerce_products.sys.ini</language>
        <language tag="es-ES">es-ES/mod_j2commerce_products.ini</language>
        <language tag="es-ES">es-ES/mod_j2commerce_products.sys.ini</language>
        <language tag="fi-FI">fi-FI/mod_j2commerce_products.ini</language>
        <language tag="fi-FI">fi-FI/mod_j2commerce_products.sys.ini</language>
        <language tag="fr-FR">fr-FR/mod_j2commerce_products.ini</language>
        <language tag="fr-FR">fr-FR/mod_j2commerce_products.sys.ini</language>
        <language tag="he-IL">he-IL/mod_j2commerce_products.ini</language>
        <language tag="he-IL">he-IL/mod_j2commerce_products.sys.ini</language>
        <language tag="it-IT">it-IT/mod_j2commerce_products.ini</language>
        <language tag="it-IT">it-IT/mod_j2commerce_products.sys.ini</language>
        <language tag="ja-JP">ja-JP/mod_j2commerce_products.ini</language>
        <language tag="ja-JP">ja-JP/mod_j2commerce_products.sys.ini</language>
        <language tag="nb-NO">nb-NO/mod_j2commerce_products.ini</language>
        <language tag="nb-NO">nb-NO/mod_j2commerce_products.sys.ini</language>
        <language tag="nl-NL">nl-NL/mod_j2commerce_products.ini</language>
        <language tag="nl-NL">nl-NL/mod_j2commerce_products.sys.ini</language>
        <language tag="pl-PL">pl-PL/mod_j2commerce_products.ini</language>
        <language tag="pl-PL">pl-PL/mod_j2commerce_products.sys.ini</language>
        <language tag="pt-PT">pt-PT/mod_j2commerce_products.ini</language>
        <language tag="pt-PT">pt-PT/mod_j2commerce_products.sys.ini</language>
        <language tag="ru-RU">ru-RU/mod_j2commerce_products.ini</language>
        <language tag="ru-RU">ru-RU/mod_j2commerce_products.sys.ini</language>
        <language tag="sv-SE">sv-SE/mod_j2commerce_products.ini</language>
        <language tag="sv-SE">sv-SE/mod_j2commerce_products.sys.ini</language>
        <language tag="tr-TR">tr-TR/mod_j2commerce_products.ini</language>
        <language tag="tr-TR">tr-TR/mod_j2commerce_products.sys.ini</language>
        <language tag="zh-TW">zh-TW/mod_j2commerce_products.ini</language>
        <language tag="zh-TW">zh-TW/mod_j2commerce_products.sys.ini</language>
    </languages>

    <config>
        <fields name="params">
            <fieldset name="basic" label="MOD_J2COMMERCE_PRODUCTS_FIELDSET_BASIC"
                addfieldprefix="J2Commerce\Component\J2commerce\Administrator\Field">

                <field name="product_source" type="list" default="latest"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SOURCE"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_SOURCE_DESC">
                    <option value="latest">MOD_J2COMMERCE_PRODUCTS_SOURCE_LATEST</option>
                    <option value="featured">MOD_J2COMMERCE_PRODUCTS_SOURCE_FEATURED</option>
                    <option value="category">MOD_J2COMMERCE_PRODUCTS_SOURCE_CATEGORY</option>
                    <option value="selected_products">MOD_J2COMMERCE_PRODUCTS_SOURCE_SELECTED</option>
                    <option value="tag">MOD_J2COMMERCE_PRODUCTS_SOURCE_TAG</option>
                    <option value="bestselling">MOD_J2COMMERCE_PRODUCTS_SOURCE_BESTSELLING</option>
                    <option value="popular">MOD_J2COMMERCE_PRODUCTS_SOURCE_POPULAR</option>
                </field>

                <field name="category_ids" type="category" extension="com_content"
                    multiple="true" default=""
                    layout="joomla.form.field.list-fancy-select"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_CATEGORIES"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_CATEGORIES_DESC"
                    published="1"
                    showon="product_source:category">
                    <option value="">JALL</option>
                </field>

                <field name="product_ids" type="moduleproductadd"
                    addfieldprefix="J2Commerce\Module\Products\Site\Field"
                    label="COM_J2COMMERCE_SELECT_PRODUCTS"
                    showon="product_source:selected_products" />

                <field name="tag_ids" type="tag" multiple="true" default=""
                       label="MOD_J2COMMERCE_PRODUCTS_FIELD_TAGS"
                       description="MOD_J2COMMERCE_PRODUCTS_FIELD_TAGS_DESC"
                       showon="product_source:tag">
                </field>

                <field name="product_types" type="ProductType" multiple="true" default=""
                    layout="joomla.form.field.list-fancy-select"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_PRODUCT_TYPES"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_PRODUCT_TYPES_DESC">
                    <option value="">JALL</option>
                </field>

                <field name="featured_only" type="radio" layout="joomla.form.field.radio.switcher"
                    default="0" filter="integer"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_FEATURED_ONLY"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_FEATURED_ONLY_DESC">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="count" type="number" default="8" min="1" max="50"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_COUNT"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_COUNT_DESC" />

                <field name="list_ordering" type="list" default="latest"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_ORDERING"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_ORDERING_DESC">
                    <option value="latest">MOD_J2COMMERCE_PRODUCTS_ORDERING_LATEST</option>
                    <option value="title_asc">MOD_J2COMMERCE_PRODUCTS_ORDERING_TITLE_ASC</option>
                    <option value="title_desc">MOD_J2COMMERCE_PRODUCTS_ORDERING_TITLE_DESC</option>
                    <option value="article_ordering">MOD_J2COMMERCE_PRODUCTS_ORDERING_ARTICLE</option>
                    <option value="random">MOD_J2COMMERCE_PRODUCTS_ORDERING_RANDOM</option>
                    <option value="popular">MOD_J2COMMERCE_PRODUCTS_ORDERING_POPULAR</option>
                    <option value="bestselling">MOD_J2COMMERCE_PRODUCTS_ORDERING_BESTSELLING</option>
                </field>

            </fieldset>

            <fieldset name="layout" label="MOD_J2COMMERCE_PRODUCTS_FIELDSET_LAYOUT">

                <field name="layout_type" type="list" default="grid"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_LAYOUT"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_LAYOUT_DESC">
                    <option value="grid">MOD_J2COMMERCE_PRODUCTS_LAYOUT_GRID</option>
                    <option value="slider">MOD_J2COMMERCE_PRODUCTS_LAYOUT_SLIDER</option>
                </field>

                <field name="list_no_of_columns" type="list" default="3"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_COLUMNS"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_COLUMNS_DESC"
                    showon="layout_type:grid">
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                    <option value="6">6</option>
                </field>

                <field name="slides_per_view" type="number" default="4" min="1" max="6"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SLIDES"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_SLIDES_DESC"
                    showon="layout_type:slider" />

                <field name="space_between" type="number" default="20" min="0" max="60"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SPACING"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_SPACING_DESC"
                    showon="layout_type:slider" />

                <field name="autoplay" type="radio" layout="joomla.form.field.radio.switcher" default="0"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_AUTOPLAY"
                    showon="layout_type:slider">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="autoplay_delay" type="number" default="4" min="1" max="30"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_AUTOPLAY_DELAY"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_AUTOPLAY_DELAY_DESC"
                    showon="layout_type:slider AND autoplay:1" />

                <field name="loop" type="radio" layout="joomla.form.field.radio.switcher" default="0"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_LOOP"
                    showon="layout_type:slider">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="navigation" type="radio" layout="joomla.form.field.radio.switcher" default="1"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_NAVIGATION"
                    showon="layout_type:slider">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="pagination" type="radio" layout="joomla.form.field.radio.switcher" default="0"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_PAGINATION"
                    showon="layout_type:slider">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

            </fieldset>

            <fieldset name="display" label="MOD_J2COMMERCE_PRODUCTS_FIELDSET_DISPLAY">

                <field name="subtemplate" type="Subtemplate" default="app_bootstrap5"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SUBTEMPLATE"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_SUBTEMPLATE_DESC" />

                <field name="module_image_thumbnail_width" type="number" default="200" min="50" max="800"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_IMAGE_WIDTH"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_IMAGE_WIDTH_DESC" />

                <field name="list_show_image" type="radio" layout="joomla.form.field.radio.switcher" default="1"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SHOW_IMAGE">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="list_show_title" type="radio" layout="joomla.form.field.radio.switcher" default="1"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SHOW_TITLE">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="list_link_title" type="radio" layout="joomla.form.field.radio.switcher" default="1"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_LINK_TITLE">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="list_image_link_to_product" type="radio" layout="joomla.form.field.radio.switcher" default="1"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_LINK_IMAGE">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="list_show_description" type="radio" layout="joomla.form.field.radio.switcher" default="0"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SHOW_DESCRIPTION">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="list_show_product_sku" type="radio" layout="joomla.form.field.radio.switcher" default="0"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SHOW_SKU">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="list_show_cart" type="list" default="1"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SHOW_CART">
                    <option value="0">JHIDE</option>
                    <option value="1">MOD_J2COMMERCE_PRODUCTS_CART_WITH_OPTIONS</option>
                    <option value="2">MOD_J2COMMERCE_PRODUCTS_CART_NO_OPTIONS</option>
                    <option value="3">MOD_J2COMMERCE_PRODUCTS_CART_DETAIL_PAGE</option>
                </field>

                <field name="list_show_price" type="radio" layout="joomla.form.field.radio.switcher" default="1"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SHOW_PRICE">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="list_show_product_stock" type="radio" layout="joomla.form.field.radio.switcher" default="0"
                    filter="integer"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SHOW_STOCK">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="list_show_product_base_price" type="radio" layout="joomla.form.field.radio.switcher" default="1"
                    filter="integer"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SHOW_BASE_PRICE">
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>

                <field name="list_show_product_special_price" type="radio" layout="joomla.form.field.radio.switcher" default="1"
                    filter="integer"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SHOW_SPECIAL_PRICE">
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>

                <field name="list_show_discount_percentage" type="radio" layout="joomla.form.field.radio.switcher" default="1"
                    filter="integer"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SHOW_DISCOUNT">
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>

                <field name="list_image_type" type="list" default="thumbimage"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_IMAGE_TYPE"
                    showon="list_show_image:1">
                    <option value="thumbimage">MOD_J2COMMERCE_PRODUCTS_IMAGE_THUMBNAIL</option>
                    <option value="mainimage">MOD_J2COMMERCE_PRODUCTS_IMAGE_MAIN</option>
                </field>

                <field name="list_description_length" type="number" default="150" min="0" max="500"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_DESC_LENGTH"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_DESC_LENGTH_DESC"
                    showon="list_show_description:1" />

                <field name="show_qty_field" type="radio" layout="joomla.form.field.radio.switcher" default="1"
                    filter="integer"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_SHOW_QTY"
                    showon="list_show_cart:1">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="image_for_product_options" type="radio" layout="joomla.form.field.radio.switcher" default="0"
                    filter="integer"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_OPTION_IMAGES"
                    showon="list_show_cart:1">
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>

                <field name="product_option_price" type="radio" layout="joomla.form.field.radio.switcher" default="1"
                    filter="integer"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_OPTION_PRICE"
                    showon="list_show_cart:1">
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>

                <field name="addtocart_button_class" type="text" default="btn btn-primary"
                    label="MOD_J2COMMERCE_PRODUCTS_FIELD_CART_BTN_CLASS"
                    description="MOD_J2COMMERCE_PRODUCTS_FIELD_CART_BTN_CLASS_DESC"
                    showon="list_show_cart:1" />

            </fieldset>

            <fieldset name="advanced" label="JGLOBAL_FIELDSET_ADVANCED">
                <field
                    name="moduleclass_sfx"
                    type="text"
                    default=""
                    label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                    validate="CssIdentifier"
                />
            </fieldset>
        </fields>
    </config>
</extension>
