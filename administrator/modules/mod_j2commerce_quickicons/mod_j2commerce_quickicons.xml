    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="show_dashboard"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                    label="MOD_J2COMMERCE_QUICKICONS_SHOW_DASHBOARD"
                    description="MOD_J2COMMERCE_QUICKICONS_SHOW_DASHBOARD_DESC"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_orders"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                    label="MOD_J2COMMERCE_QUICKICONS_SHOW_ORDERS"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_products"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                    label="MOD_J2COMMERCE_QUICKICONS_SHOW_PRODUCTS"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_customers"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                    label="MOD_J2COMMERCE_QUICKICONS_SHOW_CUSTOMERS"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_apps"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                    label="MOD_J2COMMERCE_QUICKICONS_SHOW_APPS"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_payment"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                    label="MOD_J2COMMERCE_QUICKICONS_SHOW_PAYMENT"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_shipping"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                    label="MOD_J2COMMERCE_QUICKICONS_SHOW_SHIPPING"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_statistics"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                    label="MOD_J2COMMERCE_QUICKICONS_SHOW_STATISTICS"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_reports"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                    label="MOD_J2COMMERCE_QUICKICONS_SHOW_REPORTS"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_config"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                    label="MOD_J2COMMERCE_QUICKICONS_SHOW_CONFIG"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_plugin_icons"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                    label="MOD_J2COMMERCE_QUICKICONS_SHOW_PLUGIN_ICONS"
                    description="MOD_J2COMMERCE_QUICKICONS_SHOW_PLUGIN_ICONS_DESC"
