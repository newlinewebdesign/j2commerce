    <version>6.0.7</version>
    <description>MOD_J2COMMERCE_QUICKICONS_DESC</description>
    <namespace path="src">J2Commerce\Module\J2commerceQuickicons</namespace>

    <files>
        <folder module="mod_j2commerce_quickicons">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>

