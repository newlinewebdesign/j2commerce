        <language tag="nl-NL">nl-NL/mod_j2commerce_stats.ini</language>
        <language tag="nl-NL">nl-NL/mod_j2commerce_stats.sys.ini</language>
        <language tag="fr-FR">fr-FR/mod_j2commerce_stats.ini</language>
        <language tag="fr-FR">fr-FR/mod_j2commerce_stats.sys.ini</language>
        <language tag="ru-RU">ru-RU/mod_j2commerce_stats.ini</language>
        <language tag="ru-RU">ru-RU/mod_j2commerce_stats.sys.ini</language>
        <language tag="el-GR">el-GR/mod_j2commerce_stats.ini</language>
        <language tag="el-GR">el-GR/mod_j2commerce_stats.sys.ini</language>
        <language tag="he-IL">he-IL/mod_j2commerce_stats.ini</language>
        <language tag="he-IL">he-IL/mod_j2commerce_stats.sys.ini</language>
        <language tag="ar-AA">ar-AA/mod_j2commerce_stats.ini</language>
        <language tag="ar-AA">ar-AA/mod_j2commerce_stats.sys.ini</language>
        <language tag="ja-JP">ja-JP/mod_j2commerce_stats.ini</language>
        <language tag="ja-JP">ja-JP/mod_j2commerce_stats.sys.ini</language>
        <language tag="pl-PL">pl-PL/mod_j2commerce_stats.ini</language>
