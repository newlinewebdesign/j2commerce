<?xml version="1.0" encoding="utf-8"?>
<extension type="module" method="upgrade" position="j2commerce-module-position-5" client="administrator">
    <name>MOD_J2COMMERCE_STATS</name>
    <creationDate>January 2026</creationDate>
    <author>J2Commerce, LLC</author>
    <copyright>(C) 2024-2026 J2Commerce, LLC. All rights reserved.</copyright>
    <license>GNU General Public License v2 or later</license>
    <authorEmail>support@j2commerce.com</authorEmail>
    <authorUrl>https://www.j2commerce.com</authorUrl>
    <version>6.0.7</version>
    <description>MOD_J2COMMERCE_STATS_XML_DESCRIPTION</description>
    <namespace path="src">J2Commerce\Module\Stats</namespace>
    <files>
        <folder module="mod_j2commerce_stats">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>

    <languages folder="language">
        <language tag="en-GB">en-GB/mod_j2commerce_stats.ini</language>
        <language tag="en-GB">en-GB/mod_j2commerce_stats.sys.ini</language>
    </languages>

    <config>
        <fields name="params">
            <fieldset name="basic" addfieldprefix="J2Commerce\Module\Stats\Administrator\Field">
                <field
                    name="order_status"
                    type="OrderStatus"
                    multiple="true"
                    label="MOD_J2COMMERCE_STATS_FIELD_ORDER_STATUS"
                    description="MOD_J2COMMERCE_STATS_FIELD_ORDER_STATUS_DESC"
                    addfieldprefix="J2Commerce\Component\J2commerce\Administrator\Field"
                    default="*"
                    layout="joomla.form.field.list-fancy-select"
                >
                    <option value="*">MOD_J2COMMERCE_STATS_ALL_STATUSES</option>
                </field>
            </fieldset>
            <fieldset name="advanced">
                <field
                    name="layout"
                    class="form-select"
                    type="modulelayout"
                    label="JFIELD_ALT_LAYOUT_LABEL"
                    description="JFIELD_ALT_MODULE_LAYOUT_DESC"
                />
                <field
                    name="moduleclass_sfx"
                    type="textarea"
                    label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                    description="COM_MODULES_FIELD_MODULECLASS_SFX_DESC"
                    rows="3"
                />
                <field
                    name="owncache"
                    type="list"
                    label="COM_MODULES_FIELD_CACHING_LABEL"
                    description="COM_MODULES_FIELD_CACHING_DESC"
                    default="1"
                    filter="integer"
                >
                    <option value="1">JGLOBAL_USE_GLOBAL</option>
                    <option value="0">COM_MODULES_FIELD_VALUE_NOCACHING</option>
                </field>
                <field
                    name="cache_time"
                    type="number"
                    label="COM_MODULES_FIELD_CACHE_TIME_LABEL"
                    description="COM_MODULES_FIELD_CACHE_TIME_DESC"
                    default="900"
                    filter="integer"
                />
            </fieldset>
        </fields>
    </config>
</extension>
