<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>COM_J2COMMERCEMIGRATOR</name>
    <author>J2Commerce, LLC</author>
    <authorUrl>https://www.j2commerce.com</authorUrl>
    <copyright>(C)2024-2026 J2Commerce, LLC</copyright>
    <license>GNU General Public License version 2 or later</license>
    <version>6.0.0</version>
    <description>COM_J2COMMERCEMIGRATOR_XML_DESCRIPTION</description>
    <namespace path="src">J2Commerce\Component\J2commercemigrator</namespace>

    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>

    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>

    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>

    <scriptfile>script.j2commercemigrator.php</scriptfile>

    <files folder="administrator/components/com_j2commercemigrator">
        <folder>services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
        <folder>sql</folder>
        <file>j2commercemigrator.xml</file>
        <file>script.j2commercemigrator.php</file>
        <file>access.xml</file>
        <file>config.xml</file>
    </files>

    <media folder="media/com_j2commercemigrator" destination="com_j2commercemigrator">
        <folder>js</folder>
        <folder>css</folder>
    </media>

    <languages folder="administrator/components/com_j2commercemigrator">
        <language tag="en-US">language/en-US/com_j2commercemigrator.ini</language>
        <language tag="en-US">language/en-US/com_j2commercemigrator.sys.ini</language>
        <language tag="en-GB">language/en-GB/com_j2commercemigrator.ini</language>
        <language tag="en-GB">language/en-GB/com_j2commercemigrator.sys.ini</language>
    </languages>

    <administration>
        <menu img="fa-solid fa-right-left">COM_J2COMMERCEMIGRATOR</menu>
        <submenu>
            <menu link="option=com_j2commercemigrator">COM_J2COMMERCEMIGRATOR_SUBMENU_DASHBOARD</menu>
            <menu link="option=com_j2commercemigrator&amp;view=runs">COM_J2COMMERCEMIGRATOR_SUBMENU_RUNS</menu>
        </submenu>
        <files folder="administrator/components/com_j2commercemigrator">
            <folder>services</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
            <folder>sql</folder>
            <folder>language</folder>
            <file>j2commercemigrator.xml</file>
            <file>script.j2commercemigrator.php</file>
            <file>access.xml</file>
            <file>config.xml</file>
        </files>
        <languages folder="administrator/components/com_j2commercemigrator">
            <language tag="en-US">language/en-US/com_j2commercemigrator.ini</language>
            <language tag="en-US">language/en-US/com_j2commercemigrator.sys.ini</language>
            <language tag="en-GB">language/en-GB/com_j2commercemigrator.ini</language>
            <language tag="en-GB">language/en-GB/com_j2commercemigrator.sys.ini</language>
        </languages>
    </administration>
</extension>
