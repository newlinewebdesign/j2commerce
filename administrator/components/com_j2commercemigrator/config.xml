<?xml version="1.0" encoding="utf-8"?>
<config>
    <fieldset
        name="component"
        label="COM_J2COMMERCEMIGRATOR_CONFIG_COMPONENT_LABEL"
    >
        <field
            name="default_batch_size"
            type="number"
            label="COM_J2COMMERCEMIGRATOR_FIELD_DEFAULT_BATCH_SIZE"
            description="COM_J2COMMERCEMIGRATOR_FIELD_DEFAULT_BATCH_SIZE_DESC"
            default="200"
            min="10"
            max="2000"
            step="10"
            filter="int"
        />
        <field
            name="default_conflict_mode"
            type="list"
            label="COM_J2COMMERCEMIGRATOR_FIELD_DEFAULT_CONFLICT_MODE"
            description="COM_J2COMMERCEMIGRATOR_FIELD_DEFAULT_CONFLICT_MODE_DESC"
            default="skip"
            filter="cmd"
        >
            <option value="skip">COM_J2COMMERCEMIGRATOR_CONFLICT_MODE_SKIP</option>
            <option value="overwrite">COM_J2COMMERCEMIGRATOR_CONFLICT_MODE_OVERWRITE</option>
            <option value="merge">COM_J2COMMERCEMIGRATOR_CONFLICT_MODE_MERGE</option>
            <option value="report-only">COM_J2COMMERCEMIGRATOR_CONFLICT_MODE_REPORT_ONLY</option>
        </field>
        <field
            name="log_enabled"
            type="radio"
            label="COM_J2COMMERCEMIGRATOR_FIELD_LOG_ENABLED"
            description="COM_J2COMMERCEMIGRATOR_FIELD_LOG_ENABLED_DESC"
            layout="joomla.form.field.radio.switcher"
            default="1"
            filter="integer"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
    </fieldset>
</config>
