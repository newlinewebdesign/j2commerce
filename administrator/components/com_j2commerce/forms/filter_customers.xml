<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="COM_J2COMMERCE_FILTER_SEARCH_LABEL"
            description="COM_J2COMMERCE_FILTER_SEARCH_DESC"
            hint="JSEARCH_FILTER"
        />

        <field
            name="country_id"
            type="country"
            label="COM_J2COMMERCE_FILTER_COUNTRY"
            onchange="this.form.submit();"
            addfieldprefix="J2Commerce\Component\J2commerce\Administrator\Field"
        >
            <option value="">COM_J2COMMERCE_SELECT_COUNTRY</option>
        </field>
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="customer_name ASC"
            onchange="this.form.submit();"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="customer_name ASC">COM_J2COMMERCE_HEADING_CUSTOMER_NAME_ASC</option>
            <option value="customer_name DESC">COM_J2COMMERCE_HEADING_CUSTOMER_NAME_DESC</option>
            <option value="a.email ASC">COM_J2COMMERCE_HEADING_EMAIL_ASC</option>
            <option value="a.email DESC">COM_J2COMMERCE_HEADING_EMAIL_DESC</option>
            <option value="a.city ASC">COM_J2COMMERCE_HEADING_CITY_ASC</option>
            <option value="a.city DESC">COM_J2COMMERCE_HEADING_CITY_DESC</option>
            <option value="c.country_name ASC">COM_J2COMMERCE_HEADING_COUNTRY_ASC</option>
            <option value="c.country_name DESC">COM_J2COMMERCE_HEADING_COUNTRY_DESC</option>
            <option value="z.zone_name ASC">COM_J2COMMERCE_HEADING_ZONE_ASC</option>
            <option value="z.zone_name DESC">COM_J2COMMERCE_HEADING_ZONE_DESC</option>
            <option value="a.j2commerce_address_id ASC">JGRID_HEADING_ID_ASC</option>
            <option value="a.j2commerce_address_id DESC">JGRID_HEADING_ID_DESC</option>
        </field>

        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>
