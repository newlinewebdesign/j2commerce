<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="COM_J2COMMERCE_FILTER_SEARCH_LABEL"
            description="COM_J2COMMERCE_FILTER_SEARCH_DESC"
            hint="JSEARCH_FILTER"
            inputmode="search"
        />

        <field
            name="enabled"
            type="status"
            label="JOPTION_SELECT_PUBLISHED"
            optionsFilter="*,-2,0,1"
            class="js-select-submit-on-change"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>

        <field
            name="geozone_id"
            type="sql"
            label="COM_J2COMMERCE_FIELD_GEOZONE"
            onchange="this.form.submit();"
            query="SELECT j2commerce_geozone_id AS value, geozone_name AS text FROM #__j2commerce_geozones WHERE enabled = 1 ORDER BY geozone_name"
            key_field="value"
            value_field="text"
        >
            <option value="">COM_J2COMMERCE_SELECT_GEOZONE</option>
        </field>
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="a.taxrate_name ASC"
            onchange="this.form.submit();"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.enabled ASC">JSTATUS_ASC</option>
            <option value="a.enabled DESC">JSTATUS_DESC</option>
            <option value="a.taxrate_name ASC">COM_J2COMMERCE_HEADING_TAXRATE_NAME_ASC</option>
            <option value="a.taxrate_name DESC">COM_J2COMMERCE_HEADING_TAXRATE_NAME_DESC</option>
            <option value="a.tax_percent ASC">COM_J2COMMERCE_HEADING_TAX_PERCENT_ASC</option>
            <option value="a.tax_percent DESC">COM_J2COMMERCE_HEADING_TAX_PERCENT_DESC</option>
            <option value="g.geozone_name ASC">COM_J2COMMERCE_HEADING_GEOZONE_NAME_ASC</option>
            <option value="g.geozone_name DESC">COM_J2COMMERCE_HEADING_GEOZONE_NAME_DESC</option>
            <option value="a.j2commerce_taxrate_id ASC">JGRID_HEADING_ID_ASC</option>
            <option value="a.j2commerce_taxrate_id DESC">JGRID_HEADING_ID_DESC</option>
        </field>

        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>