<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="basic" label="COM_J2COMMERCE_FIELDSET_BASIC">
        <field
            name="j2commerce_length_id"
            type="hidden"
            default="0"
        />

        <field
            name="length_title"
            type="text"
            label="COM_J2COMMERCE_FIELD_LENGTH_TITLE"
            required="true"
            maxlength="255"
            class="w-100"
        />

        <field
            name="length_unit"
            type="text"
            label="COM_J2COMMERCE_FIELD_LENGTH_UNIT"
            description="COM_J2COMMERCE_FIELD_LENGTH_UNIT_DESC"
            required="true"
            maxlength="4"
            size="10"
        />

        <field
            name="length_value"
            type="number"
            label="COM_J2COMMERCE_FIELD_LENGTH_VALUE"
            description="COM_J2COMMERCE_FIELD_LENGTH_VALUE_DESC"
            required="true"
            min="0.00000001"
            step="0.00000001"
            default="1.00000000"
        />

        <!-- Number of decimal places for this length unit -->
        <field
            name="num_decimals"
            type="number"
            label="COM_J2COMMERCE_FIELD_NUM_DECIMALS"
            description="COM_J2COMMERCE_FIELD_LENGTH_NUM_DECIMALS_DESC"
            default="2"
            min="0"
            max="6"
            step="1"
            filter="integer"
        />

        <field
            name="enabled"
            type="list"
            label="JSTATUS"
            description="JFIELD_PUBLISHED_DESC"
            default="1"
            class="form-select-color-state"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="-2">JTRASHED</option>
        </field>

        <field
            name="ordering"
            type="ordering"
            label="JFIELD_ORDERING_LABEL"
            description="JFIELD_ORDERING_DESC"
            default="0"
            content_type="com_j2commerce.length"
        />
    </fieldset>
</form>