<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="basic" label="COM_J2COMMERCE_FIELDSET_BASIC">
        <field
            name="j2commerce_taxrate_id"
            type="hidden"
            default="0"
        />

        <field
            name="taxrate_name"
            type="text"
            label="COM_J2COMMERCE_FIELD_TAXRATE_NAME"
            description="COM_J2COMMERCE_FIELD_TAXRATE_NAME_DESC"
            required="true"
            maxlength="255"
            class="w-100"
        />

        <field
            name="tax_percent"
            type="number"
            label="COM_J2COMMERCE_FIELD_TAX_PERCENT"
            description="COM_J2COMMERCE_FIELD_TAX_PERCENT_DESC"
            required="true"
            min="0"
            max="100"
            step="0.001"
            default="0"
        />

        <field
            name="geozone_id"
            type="geozone"
            label="COM_J2COMMERCE_FIELD_GEOZONE"
            description="COM_J2COMMERCE_FIELD_GEOZONE_DESC"
            required="true"
            class="form-select"
            addfieldprefix ="J2Commerce\Component\J2commerce\Administrator\Field"
        />

        <field
            name="enabled"
            type="list"
            label="JSTATUS"
            description="JFIELD_PUBLISHED_DESC"
            default="1"
            class="form-select-color-state"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="-2">JTRASHED</option>
        </field>

        <field
            name="ordering"
            type="ordering"
            label="JFIELD_ORDERING_LABEL"
            description="JFIELD_ORDERING_DESC"
            default="0"
            content_type="com_j2commerce.taxrate"
        />
    </fieldset>
</form>
