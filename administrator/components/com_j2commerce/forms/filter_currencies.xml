<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="COM_J2COMMERCE_FILTER_SEARCH_LABEL"
            description="COM_J2COMMERCE_FILTER_SEARCH_DESC"
            hint="JSEARCH_FILTER"
            inputmode="search"
        />

        <field
            name="enabled"
            type="status"
            label="JOPTION_SELECT_PUBLISHED"
            optionsFilter="*,-2,0,1"
            class="js-select-submit-on-change"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="a.currency_title ASC"
            onchange="this.form.submit();"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.currency_title ASC">COM_J2COMMERCE_HEADING_CURRENCY_TITLE_ASC</option>
            <option value="a.currency_title DESC">COM_J2COMMERCE_HEADING_CURRENCY_TITLE_DESC</option>
            <option value="a.currency_code ASC">COM_J2COMMERCE_HEADING_CURRENCY_CODE_ASC</option>
            <option value="a.currency_code DESC">COM_J2COMMERCE_HEADING_CURRENCY_CODE_DESC</option>
            <option value="a.currency_symbol ASC">COM_J2COMMERCE_HEADING_CURRENCY_SYMBOL_ASC</option>
            <option value="a.currency_symbol DESC">COM_J2COMMERCE_HEADING_CURRENCY_SYMBOL_DESC</option>
            <option value="a.currency_value ASC">COM_J2COMMERCE_HEADING_CURRENCY_VALUE_ASC</option>
            <option value="a.currency_value DESC">COM_J2COMMERCE_HEADING_CURRENCY_VALUE_DESC</option>
            <option value="a.j2commerce_currency_id ASC">COM_J2COMMERCE_HEADING_ID_ASC</option>
            <option value="a.j2commerce_currency_id DESC">COM_J2COMMERCE_HEADING_ID_DESC</option>
        </field>

        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>