<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="details">
        <field
            name="j2commerce_filter_id"
            type="hidden"
            default="0"
        />

        <field
            name="group_id"
            type="hidden"
            default="0"
        />

        <field
            name="filter_name"
            type="text"
            label="COM_J2COMMERCE_FILTER_NAME"
            description="COM_J2COMMERCE_FILTER_NAME_DESC"
            required="true"
            maxlength="255"
            class="form-control"
        />

        <field
            name="ordering"
            type="hidden"
            default="0"
        />
    </fieldset>
</form>
