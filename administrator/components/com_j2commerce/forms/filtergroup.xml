<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="details">
        <field
            name="id"
            type="hidden"
            default="0"
        />

        <field
            name="group_name"
            type="text"
            label="COM_J2COMMERCE_FILTERGROUP_GROUP_NAME"
            description="COM_J2COMMERCE_FILTERGROUP_GROUP_NAME_DESC"
            required="true"
            maxlength="255"
            class="form-control"
        />
    </fieldset>

    <fieldset name="global">
        <field
            name="published"
            type="list"
            label="JSTATUS"
            description="JFIELD_PUBLISHED_DESC"
            default="1"
            class="form-select-color-state"
            >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="-2">JTRASHED</option>
        </field>

        <field
            name="ordering"
            type="ordering"
            label="JFIELD_ORDERING_LABEL"
            description="JFIELD_ORDERING_DESC"
            default="0"
            content_type="com_j2commerce.filtergroup"
        />
    </fieldset>

    <fieldset name="filters" label="COM_J2COMMERCE_FILTERGROUP_FILTERS">
        <field
            name="filters"
            type="subform"
            label="COM_J2COMMERCE_FILTERGROUP_FILTERS"
            description="COM_J2COMMERCE_FILTERGROUP_FILTERS_DESC"
            layout="joomla.form.field.subform.repeatable"
            formsource="administrator/components/com_j2commerce/forms/filter.xml"
            min="0"
            max="500"
            multiple="true"
            buttons="add,remove,move"
            hiddenLabel="true"
        />
    </fieldset>
</form>
