<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="COM_J2COMMERCE_FILTER_SEARCH_LABEL"
            description="COM_J2COMMERCE_FILTER_SEARCH_DESC"
            hint="JSEARCH_FILTER"
            inputmode="search"
        />

        <field
            name="product_type"
            type="ProductType"
            label="COM_J2COMMERCE_FILTER_PRODUCT_TYPE"
            onchange="this.form.submit();"
            addfieldprefix="J2Commerce\Component\J2commerce\Administrator\Field"
        >
            <option value="">COM_J2COMMERCE_FILTER_SELECT_PRODUCT_TYPE</option>
        </field>

        <field
            name="manufacturer_id"
            type="Manufacturers"
            label="COM_J2COMMERCE_FILTER_MANUFACTURER"
            addfieldprefix="J2Commerce\Component\J2commerce\Administrator\Field"
            onchange="this.form.submit();"
        >
            <option value="">COM_J2COMMERCE_FILTER_SELECT_MANUFACTURER</option>
        </field>

        <field
            name="vendor_id"
            type="Vendors"
            label="COM_J2COMMERCE_FILTER_VENDOR"
            addfieldprefix="J2Commerce\Component\J2commerce\Administrator\Field"
            onchange="this.form.submit();"
        >
            <option value="">COM_J2COMMERCE_FILTER_SELECT_VENDOR</option>
        </field>

        <field
            name="taxprofile_id"
            type="TaxProfile"
            label="COM_J2COMMERCE_FILTER_TAX_PROFILE"
            addfieldprefix="J2Commerce\Component\J2commerce\Administrator\Field"
            onchange="this.form.submit();"
        >
            <option value="">COM_J2COMMERCE_SELECT_TAXPROFILE</option>
        </field>

        <field
            name="visibility"
            type="list"
            label="COM_J2COMMERCE_FILTER_VISIBILITY"
            onchange="this.form.submit();"
        >
            <option value="">COM_J2COMMERCE_FILTER_SELECT_VISIBILITY</option>
            <option value="1">JYES</option>
            <option value="0">JNO</option>
        </field>

        <field
            name="date_from"
            type="calendar"
            label="COM_J2COMMERCE_FILTER_DATE_FROM"
            hint="COM_J2COMMERCE_FILTER_DATE_FROM"
            format="%Y-%m-%d"
            showtime="false"
            onchange="this.form.submit();"
        />

        <field
            name="date_to"
            type="calendar"
            label="COM_J2COMMERCE_FILTER_DATE_TO"
            hint="COM_J2COMMERCE_FILTER_DATE_TO"
            format="%Y-%m-%d"
            showtime="false"
            onchange="this.form.submit();"
        />

        <field
            name="product_id_from"
            type="text"
            label="COM_J2COMMERCE_FILTER_PRODUCT_ID_FROM"
            hint="COM_J2COMMERCE_FILTER_PRODUCT_ID_FROM"
            inputmode="numeric"
            onchange="this.form.submit();"
        />

        <field
            name="product_id_to"
            type="text"
            label="COM_J2COMMERCE_FILTER_PRODUCT_ID_TO"
            hint="COM_J2COMMERCE_FILTER_PRODUCT_ID_TO"
            inputmode="numeric"
            onchange="this.form.submit();"
        />

        <field
            name="price_from"
            type="text"
            label="COM_J2COMMERCE_FILTER_PRICE_FROM"
            hint="COM_J2COMMERCE_FILTER_PRICE_FROM"
            inputmode="decimal"
            onchange="this.form.submit();"
        />

        <field
            name="price_to"
            type="text"
            label="COM_J2COMMERCE_FILTER_PRICE_TO"
            hint="COM_J2COMMERCE_FILTER_PRICE_TO"
            inputmode="decimal"
            onchange="this.form.submit();"
        />
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="a.j2commerce_product_id DESC"
            onchange="this.form.submit();"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.j2commerce_product_id ASC">COM_J2COMMERCE_HEADING_ID_ASC</option>
            <option value="a.j2commerce_product_id DESC">COM_J2COMMERCE_HEADING_ID_DESC</option>
            <option value="c.title ASC">COM_J2COMMERCE_HEADING_PRODUCT_NAME_ASC</option>
            <option value="c.title DESC">COM_J2COMMERCE_HEADING_PRODUCT_NAME_DESC</option>
            <option value="v.sku ASC">COM_J2COMMERCE_HEADING_SKU_ASC</option>
            <option value="v.sku DESC">COM_J2COMMERCE_HEADING_SKU_DESC</option>
            <option value="v.price ASC">COM_J2COMMERCE_HEADING_PRICE_ASC</option>
            <option value="v.price DESC">COM_J2COMMERCE_HEADING_PRICE_DESC</option>
            <option value="a.product_type ASC">COM_J2COMMERCE_HEADING_PRODUCT_TYPE_ASC</option>
            <option value="a.product_type DESC">COM_J2COMMERCE_HEADING_PRODUCT_TYPE_DESC</option>
        </field>

        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>
