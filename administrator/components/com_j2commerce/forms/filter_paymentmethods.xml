<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="COM_J2COMMERCE_FILTER_SEARCH_LABEL"
            description="COM_J2COMMERCE_FILTER_SEARCH_DESC"
            hint="JSEARCH_FILTER"
        />

        <field
            name="enabled"
            type="status"
            label="JSTATUS"
            description="JFIELD_ENABLED_DESC"
            onchange="this.form.submit();"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            statuses="*,0,1,2,-2"
            onchange="this.form.submit();"
            default="a.name ASC"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.ordering ASC">JGRID_HEADING_ORDERING_ASC</option>
            <option value="a.ordering DESC">JGRID_HEADING_ORDERING_DESC</option>
            <option value="a.enabled ASC">JSTATUS_ASC</option>
            <option value="a.enabled DESC">JSTATUS_DESC</option>
            <option value="a.name ASC">COM_J2COMMERCE_PAYMENT_METHOD_NAME_ASC</option>
            <option value="a.name DESC">COM_J2COMMERCE_PAYMENT_METHOD_NAME_DESC</option>
            <option value="a.extension_id ASC">JGRID_HEADING_ID_ASC</option>
            <option value="a.extension_id DESC">JGRID_HEADING_ID_DESC</option>
        </field>

        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            description="JGLOBAL_LIST_LIMIT_DESC"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>