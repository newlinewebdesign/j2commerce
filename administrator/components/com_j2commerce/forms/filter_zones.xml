<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="COM_J2COMMERCE_FILTER_SEARCH_LABEL"
            description="COM_J2COMMERCE_FILTER_SEARCH_DESC"
            hint="JSEARCH_FILTER"
            inputmode="search"
        />

        <field
            name="enabled"
            type="status"
            label="JOPTION_SELECT_PUBLISHED"
            optionsFilter="*,-2,0,1"
            class="js-select-submit-on-change"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>

        <field
            name="country_id"
            type="Country"
            label="COM_J2COMMERCE_FIELD_COUNTRY"
            description="COM_J2COMMERCE_FIELD_COUNTRY_DESC"
            onchange="this.form.submit();"
            addfieldprefix ="J2Commerce\Component\J2commerce\Administrator\Field"
            class="form-select"
        >
            <option value="">COM_J2COMMERCE_SELECT_COUNTRY</option>
        </field>
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="a.zone_name ASC"
            onchange="this.form.submit();"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.enabled ASC">JSTATUS_ASC</option>
            <option value="a.enabled DESC">JSTATUS_DESC</option>
            <option value="a.zone_name ASC">COM_J2COMMERCE_HEADING_ZONE_NAME_ASC</option>
            <option value="a.zone_name DESC">COM_J2COMMERCE_HEADING_ZONE_NAME_DESC</option>
            <option value="a.zone_code ASC">COM_J2COMMERCE_HEADING_ZONE_CODE_ASC</option>
            <option value="a.zone_code DESC">COM_J2COMMERCE_HEADING_ZONE_CODE_DESC</option>
            <option value="c.country_name ASC">COM_J2COMMERCE_HEADING_COUNTRY_NAME_ASC</option>
            <option value="c.country_name DESC">COM_J2COMMERCE_HEADING_COUNTRY_NAME_DESC</option>
            <option value="a.j2commerce_zone_id ASC">JGRID_HEADING_ID_ASC</option>
            <option value="a.j2commerce_zone_id DESC">JGRID_HEADING_ID_DESC</option>
        </field>

        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>
