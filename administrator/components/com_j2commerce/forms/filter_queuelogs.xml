<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="COM_J2COMMERCE_FILTER_SEARCH_LABEL"
            description="COM_J2COMMERCE_FILTER_SEARCH_DESC"
            hint="JSEARCH_FILTER"
            inputmode="search"
        />

        <field
            name="queue_type"
            type="sql"
            label="COM_J2COMMERCE_HEADING_QUEUE_TYPE"
            query="SELECT DISTINCT queue_type AS value, queue_type AS text FROM #__j2commerce_queue_logs ORDER BY queue_type ASC"
            class="js-select-submit-on-change"
            header="COM_J2COMMERCE_FILTER_SELECT_QUEUE_TYPE"
        />

        <field
            name="status"
            type="list"
            label="JSTATUS"
            class="js-select-submit-on-change"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
            <option value="running">COM_J2COMMERCE_QUEUE_LOG_STATUS_RUNNING</option>
            <option value="completed">COM_J2COMMERCE_QUEUE_STATUS_COMPLETED</option>
            <option value="error">COM_J2COMMERCE_QUEUE_LOG_STATUS_ERROR</option>
        </field>
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="a.started_at DESC"
            onchange="this.form.submit();"
            validate="options"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.started_at ASC">COM_J2COMMERCE_HEADING_CREATED_ON_ASC</option>
            <option value="a.started_at DESC">COM_J2COMMERCE_HEADING_CREATED_ON_DESC</option>
            <option value="a.status ASC">COM_J2COMMERCE_HEADING_STATUS_ASC</option>
            <option value="a.status DESC">COM_J2COMMERCE_HEADING_STATUS_DESC</option>
            <option value="a.queue_type ASC">COM_J2COMMERCE_HEADING_QUEUE_TYPE_ASC</option>
            <option value="a.queue_type DESC">COM_J2COMMERCE_HEADING_QUEUE_TYPE_DESC</option>
            <option value="a.duration_ms ASC">COM_J2COMMERCE_HEADING_DURATION_ASC</option>
            <option value="a.duration_ms DESC">COM_J2COMMERCE_HEADING_DURATION_DESC</option>
            <option value="a.items_total ASC">COM_J2COMMERCE_HEADING_TOTAL_ASC</option>
            <option value="a.items_total DESC">COM_J2COMMERCE_HEADING_TOTAL_DESC</option>
            <option value="a.j2commerce_queue_log_id ASC">COM_J2COMMERCE_HEADING_ID_ASC</option>
            <option value="a.j2commerce_queue_log_id DESC">COM_J2COMMERCE_HEADING_ID_DESC</option>
        </field>

        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>
