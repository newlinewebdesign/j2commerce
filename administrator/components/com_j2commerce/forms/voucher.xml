<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="basic" label="COM_J2COMMERCE_FIELDSET_BASIC">
        <field
            name="j2commerce_voucher_id"
            type="hidden"
            default="0"
        />

        <field
            name="voucher_code"
            type="text"
            label="COM_J2COMMERCE_FIELD_VOUCHER_CODE"
            required="true"
            maxlength="255"
            class="w-100"
        />

        <field
            name="email_to"
            type="email"
            label="COM_J2COMMERCE_FIELD_EMAIL_TO"
            maxlength="255"
            validate="email"
        />

        <field
            name="subject"
            type="text"
            label="COM_J2COMMERCE_FIELD_SUBJECT"
            maxlength="255"
        />

        <field
            name="enabled"
            type="list"
            label="JSTATUS"
            description="JFIELD_PUBLISHED_DESC"
            default="1"
            class="form-select-color-state"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
        </field>

        <field
            name="ordering"
            type="ordering"
            label="JFIELD_ORDERING_LABEL"
            description="JFIELD_ORDERING_DESC"
            default="0"
            content_type="com_j2commerce.voucher"
        />
    </fieldset>

    <fieldset name="value" label="COM_J2COMMERCE_FIELDSET_VALUE">
        <field
            name="voucher_value"
            type="number"
            label="COM_J2COMMERCE_FIELD_VOUCHER_VALUE"
            default="0.00000000"
            min="0"
            step="0.01"
        />

        <field
            name="voucher_type"
            type="list"
            label="COM_J2COMMERCE_FIELD_VOUCHER_TYPE"
            default="giftcard"
        >
            <option value="giftcard">COM_J2COMMERCE_VOUCHER_TYPE_GIFTCARD</option>
        </field>
    </fieldset>

    <fieldset name="validity" label="COM_J2COMMERCE_FIELDSET_VALIDITY">
        <field
            name="valid_from"
            type="calendar"
            label="COM_J2COMMERCE_FIELD_VALID_FROM"
            format="%Y-%m-%d %H:%M:%S"
            filter="user_utc"
            showtime="true"
            translateformat="false"
        />

        <field
            name="valid_to"
            type="calendar"
            label="COM_J2COMMERCE_FIELD_VALID_TO"
            format="%Y-%m-%d %H:%M:%S"
            filter="user_utc"
            showtime="true"
            translateformat="false"
        />
    </fieldset>

    <fieldset name="content" label="COM_J2COMMERCE_FIELDSET_CONTENT">
        <field
            name="email_body"
            type="editor"
            label="COM_J2COMMERCE_FIELD_EMAIL_BODY"
            filter="safehtml"
            buttons="true"
        />
    </fieldset>

    <fieldset name="hidden">
        <field
            name="order_id"
            type="hidden"
            default=""
        />

        <field
            name="created_on"
            type="hidden"
        />

        <field
            name="created_by"
            type="hidden"
        />
    </fieldset>
</form>
