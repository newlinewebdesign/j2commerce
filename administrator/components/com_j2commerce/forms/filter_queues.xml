<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="COM_J2COMMERCE_FILTER_SEARCH_LABEL"
            description="COM_J2COMMERCE_FILTER_SEARCH_DESC"
            hint="JSEARCH_FILTER"
            inputmode="search"
        />

        <field
            name="queue_type"
            type="sql"
            label="COM_J2COMMERCE_HEADING_QUEUE_TYPE"
            query="SELECT DISTINCT queue_type AS value, queue_type AS text FROM #__j2commerce_queues ORDER BY queue_type ASC"
            class="js-select-submit-on-change"
            header="COM_J2COMMERCE_FILTER_SELECT_QUEUE_TYPE"
        />

        <field
            name="item_type"
            type="sql"
            label="COM_J2COMMERCE_HEADING_ITEM_TYPE"
            query="SELECT DISTINCT item_type AS value, item_type AS text FROM #__j2commerce_queues ORDER BY item_type ASC"
            class="js-select-submit-on-change"
            header="COM_J2COMMERCE_FILTER_SELECT_ITEM_TYPE"
        />

        <field
            name="status"
            type="list"
            label="JSTATUS"
            class="js-select-submit-on-change"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
            <option value="pending">COM_J2COMMERCE_QUEUE_STATUS_PENDING</option>
            <option value="processing">COM_J2COMMERCE_QUEUE_STATUS_PROCESSING</option>
            <option value="completed">COM_J2COMMERCE_QUEUE_STATUS_COMPLETED</option>
            <option value="failed">COM_J2COMMERCE_QUEUE_STATUS_FAILED</option>
            <option value="dead">COM_J2COMMERCE_QUEUE_STATUS_DEAD</option>
        </field>
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="a.created_on DESC"
            onchange="this.form.submit();"
            validate="options"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.created_on ASC">COM_J2COMMERCE_HEADING_CREATED_ON_ASC</option>
            <option value="a.created_on DESC">COM_J2COMMERCE_HEADING_CREATED_ON_DESC</option>
            <option value="a.status ASC">COM_J2COMMERCE_HEADING_STATUS_ASC</option>
            <option value="a.status DESC">COM_J2COMMERCE_HEADING_STATUS_DESC</option>
            <option value="a.queue_type ASC">COM_J2COMMERCE_HEADING_QUEUE_TYPE_ASC</option>
            <option value="a.queue_type DESC">COM_J2COMMERCE_HEADING_QUEUE_TYPE_DESC</option>
            <option value="a.priority ASC">COM_J2COMMERCE_HEADING_PRIORITY_ASC</option>
            <option value="a.priority DESC">COM_J2COMMERCE_HEADING_PRIORITY_DESC</option>
            <option value="a.attempt_count ASC">COM_J2COMMERCE_HEADING_ATTEMPTS_ASC</option>
            <option value="a.attempt_count DESC">COM_J2COMMERCE_HEADING_ATTEMPTS_DESC</option>
            <option value="a.j2commerce_queue_id ASC">COM_J2COMMERCE_HEADING_ID_ASC</option>
            <option value="a.j2commerce_queue_id DESC">COM_J2COMMERCE_HEADING_ID_DESC</option>
        </field>

        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>
