<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="COM_J2COMMERCE_FILTER_SEARCH_LABEL"
            description="COM_J2COMMERCE_FILTER_SEARCH_DESC"
            hint="JSEARCH_FILTER"
            inputmode="search"
        />

        <field
            name="enabled"
            type="status"
            label="JOPTION_SELECT_PUBLISHED"
            optionsFilter="*,-2,0,1"
            class="js-select-submit-on-change"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>

        <field
            name="field_required"
            type="list"
            label="COM_J2COMMERCE_FILTER_REQUIRED"
            class="js-select-submit-on-change"
        >
            <option value="">COM_J2COMMERCE_FILTER_REQUIRED</option>
            <option value="1">COM_J2COMMERCE_REQUIRED</option>
            <option value="0">COM_J2COMMERCE_NOT_REQUIRED</option>
        </field>
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="a.ordering ASC"
            onchange="this.form.submit();"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.ordering ASC">COM_J2COMMERCE_HEADING_ORDERING_ASC</option>
            <option value="a.ordering DESC">COM_J2COMMERCE_HEADING_ORDERING_DESC</option>
            <option value="a.enabled ASC">COM_J2COMMERCE_HEADING_STATUS_ASC</option>
            <option value="a.enabled DESC">COM_J2COMMERCE_HEADING_STATUS_DESC</option>
            <option value="a.field_name ASC">COM_J2COMMERCE_HEADING_FIELD_NAME_ASC</option>
            <option value="a.field_name DESC">COM_J2COMMERCE_HEADING_FIELD_NAME_DESC</option>
            <option value="a.field_type ASC">COM_J2COMMERCE_HEADING_FIELD_TYPE_ASC</option>
            <option value="a.field_type DESC">COM_J2COMMERCE_HEADING_FIELD_TYPE_DESC</option>
            <option value="a.field_required ASC">COM_J2COMMERCE_HEADING_FIELD_REQUIRED_ASC</option>
            <option value="a.field_required DESC">COM_J2COMMERCE_HEADING_FIELD_REQUIRED_DESC</option>
            <option value="a.field_namekey ASC">COM_J2COMMERCE_HEADING_FIELD_NAMEKEY_ASC</option>
            <option value="a.field_namekey DESC">COM_J2COMMERCE_HEADING_FIELD_NAMEKEY_DESC</option>
            <option value="a.j2commerce_customfield_id ASC">COM_J2COMMERCE_HEADING_ID_ASC</option>
            <option value="a.j2commerce_customfield_id DESC">COM_J2COMMERCE_HEADING_ID_DESC</option>
        </field>

        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>