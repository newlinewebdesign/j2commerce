<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="general" label="COM_J2COMMERCE_BASIC_SETTINGS">
        <field
            name="j2commerce_emailtemplate_id"
            type="hidden"
        />

        <field
            name="email_type"
            type="EmailtypeList"
            label="COM_J2COMMERCE_EMAILTEMPLATE_EMAIL_TYPE"
            description="COM_J2COMMERCE_EMAILTEMPLATE_EMAIL_TYPE_DESC"
            addfieldprefix="J2Commerce\Component\J2commerce\Administrator\Field"
            default="transactional"
            class="form-select"
        >
            <option value="">COM_J2COMMERCE_EMAILTYPE_SELECT</option>
        </field>

        <field
            name="subject"
            type="text"
            label="COM_J2COMMERCE_EMAILTEMPLATE_SUBJECT"
            description="COM_J2COMMERCE_EMAILTEMPLATE_SUBJECT_DESC"
            size="50"
            maxlength="255"
            required="true"
            class="form-control"
        />

        <field
            name="receiver_type"
            type="list"
            label="COM_J2COMMERCE_EMAILTEMPLATE_RECEIVER_TYPE"
            description="COM_J2COMMERCE_EMAILTEMPLATE_RECEIVER_TYPE_DESC"
            class="form-select"
            default="*"
        >
            <option value="customer">COM_J2COMMERCE_EMAILTEMPLATE_RECEIVER_CUSTOMER</option>
            <option value="admin">COM_J2COMMERCE_EMAILTEMPLATE_RECEIVER_ADMIN</option>
            <option value="*">COM_J2COMMERCE_EMAILTEMPLATE_RECEIVER_BOTH</option>
        </field>



        <field
            name="language"
            type="language"
            label="JFIELD_LANGUAGE_LABEL"
            description="COM_J2COMMERCE_EMAILTEMPLATE_LANGUAGE_DESC"
            layout="joomla.form.field.list-fancy-select"
            default="*"
        >
            <option value="*">JALL</option>
        </field>

        <field
            name="orderstatus_id"
            type="OrderStatus"
            label="COM_J2COMMERCE_EMAILTEMPLATE_ORDERSTATUS"
            description="COM_J2COMMERCE_EMAILTEMPLATE_ORDERSTATUS_DESC"
            addfieldprefix ="J2Commerce\Component\J2commerce\Administrator\Field"
            layout="joomla.form.field.list-fancy-select"
            default=""
            required="false"
        >
            <option value="*">JALL</option>
        </field>

        <field
            name="group_id"
            type="usergrouplist"
            label="COM_J2COMMERCE_EMAILTEMPLATE_GROUP"
            description="COM_J2COMMERCE_EMAILTEMPLATE_GROUP_DESC"
            default=""
            multiple="false"
            layout="joomla.form.field.list-fancy-select"
        >
            <option value="*">JALL</option>
        </field>

        <field
            name="paymentmethod"
            type="PaymentMethods"
            label="COM_J2COMMERCE_EMAILTEMPLATE_PAYMENTMETHOD"
            description="COM_J2COMMERCE_EMAILTEMPLATE_PAYMENTMETHOD_DESC"
            addfieldprefix ="J2Commerce\Component\J2commerce\Administrator\Field"
            layout="joomla.form.field.list-fancy-select"
            default=""
        >
            <option value="*">JALL</option>
        </field>

    </fieldset>

    <fieldset name="content" label="COM_J2COMMERCE_EMAILTEMPLATE_TAB_CONTENT">
        <field
            name="body_source"
            type="list"
            label="COM_J2COMMERCE_EMAILTEMPLATE_BODY_SOURCE"
            description="COM_J2COMMERCE_EMAILTEMPLATE_BODY_SOURCE_DESC"
            class="form-select"
            default="visual"
        >
            <option value="visual">COM_J2COMMERCE_EMAILTEMPLATE_BODY_SOURCE_VISUAL</option>
            <option value="editor">COM_J2COMMERCE_EMAILTEMPLATE_BODY_SOURCE_EDITOR</option>
            <option value="file">COM_J2COMMERCE_EMAILTEMPLATE_BODY_SOURCE_FILE</option>
        </field>

        <field
            name="show_body_editor"
            type="radio"
            label="COM_J2COMMERCE_EMAILTEMPLATE_SHOW_BODY_EDITOR"
            layout="joomla.form.field.radio.switcher"
            default="0"
            filter="integer"
            showon="body_source:visual"
        >
            <option value="0">JHIDE</option>
            <option value="1">JSHOW</option>
        </field>

        <field
            name="body"
            type="editor"
            label="COM_J2COMMERCE_EMAILTEMPLATE_BODY"
            description="COM_J2COMMERCE_EMAILTEMPLATE_BODY_DESC"
            filter="raw"
            buttons="true"
            hide="readmore,pagebreak"
            showon="body_source:editor[OR]show_body_editor:1"
        />

        <field
            name="body_json"
            type="hidden"
            filter="raw"
        />

        <field
            name="body_source_file"
            type="file"
            label="COM_J2COMMERCE_EMAILTEMPLATE_BODY_SOURCE_FILE_LABEL"
            description="COM_J2COMMERCE_EMAILTEMPLATE_BODY_SOURCE_FILE_DESC"
            accept=".php,.html,.htm,.txt"
            showon="body_source:file"
        />

        <field
            name="show_custom_css"
            type="radio"
            label="COM_J2COMMERCE_EMAILTEMPLATE_SHOW_CUSTOM_CSS"
            layout="joomla.form.field.radio.switcher"
            default="0"
            filter="integer"
            showon="body_source:editor,visual"
        >
            <option value="0">JHIDE</option>
            <option value="1">JSHOW</option>
        </field>

        <field
            name="custom_css"
            type="textarea"
            label="COM_J2COMMERCE_EMAILTEMPLATE_CUSTOM_CSS"
            description="COM_J2COMMERCE_EMAILTEMPLATE_CUSTOM_CSS_DESC"
            rows="8"
            filter="raw"
            class="form-control font-monospace"
            showon="show_custom_css:1"
        />

        <field
            name="email_template_description"
            type="TemplateCustom"
            hiddenLabel="true"
            label="COM_J2COMMERCE_TEMPLATE_CUSTOM_FIELD_DESCRIPTION"
            description=""
            addfieldprefix ="J2Commerce\Component\J2commerce\Administrator\Field"
        />


    </fieldset>

    <fieldset name="publishing" label="COM_J2COMMERCE_EMAILTEMPLATE_TAB_PUBLISHING">
        <field
            name="enabled"
            type="list"
            label="JSTATUS"
            description="JFIELD_PUBLISHED_DESC"
            class="form-select"
            default="1"
            required="true"
        >
            <option value="0">JUNPUBLISHED</option>
            <option value="1">JPUBLISHED</option>
            <option value="-2">JTRASHED</option>
        </field>

    </fieldset>
</form>
