<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="basic" label="COM_J2COMMERCE_FIELDSET_BASIC">
        <!-- Hidden primary key field - REQUIRED -->
        <field
            name="j2commerce_orderstatus_id"
            type="hidden"
            default="0"
        />

        <!-- Main title/name field - typically full width -->
        <field
            name="orderstatus_name"
            type="text"
            label="COM_J2COMMERCE_FIELD_ORDERSTATUS_NAME"
            required="true"
            maxlength="32"
            class="w-100"
        />

        <!-- CSS Class field -->
        <field
            name="orderstatus_cssclass"
            type="text"
            label="COM_J2COMMERCE_FIELD_ORDERSTATUS_CSSCLASS"
            description="COM_J2COMMERCE_FIELD_ORDERSTATUS_CSSCLASS_DESC"
            required="true"
            hint="badge text-bg-success"
            class="w-100"
        />

        <field
            name="orderstatus_core"
            type="radio"
            label="COM_J2COMMERCE_FIELD_ORDERSTATUS_CORE"
            description="COM_J2COMMERCE_FIELD_ORDERSTATUS_CORE_DESC"
            default="0"
            layout="joomla.form.field.radio.switcher"
            filter="integer"
            disabled="true"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>

        <!-- REQUIRED: Status field for joomla.edit.global sidebar layout -->
        <field
            name="enabled"
            type="list"
            label="JSTATUS"
            description="JFIELD_PUBLISHED_DESC"
            default="1"
            class="form-select-color-state"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="-2">JTRASHED</option>
        </field>

        <!-- REQUIRED: Ordering field for joomla.edit.global sidebar layout -->
        <field
            name="ordering"
            type="ordering"
            label="JFIELD_ORDERING_LABEL"
            description="JFIELD_ORDERING_DESC"
            default="0"
            content_type="com_j2commerce.orderstatus"
        />
    </fieldset>
</form>
