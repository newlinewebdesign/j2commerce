<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="COM_J2COMMERCE_FILTER_SEARCH_LABEL"
            description="COM_J2COMMERCE_FILTER_SEARCH_DESC"
            hint="JSEARCH_FILTER"
            inputmode="search"
        />

        <field
            name="enabled"
            type="status"
            label="JOPTION_SELECT_PUBLISHED"
            optionsFilter="*,-2,0,1"
            class="js-select-submit-on-change"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>

        <field
            name="country_id"
            type="ManufacturerCountry"
            label="COM_J2COMMERCE_FILTER_COUNTRY"
            addfieldprefix="J2Commerce\Component\J2commerce\Administrator\Field"
            onchange="this.form.submit();"
        >
            <option value="">COM_J2COMMERCE_FILTER_SELECT_COUNTRY</option>
        </field>
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="a.j2commerce_manufacturer_id ASC"
            onchange="this.form.submit();"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="addr.company ASC">COM_J2COMMERCE_HEADING_MANUFACTURER_ASC</option>
            <option value="addr.company DESC">COM_J2COMMERCE_HEADING_MANUFACTURER_ASC</option>
            <option value="addr.city ASC">COM_J2COMMERCE_HEADING_CITY_ASC</option>
            <option value="addr.city DESC">COM_J2COMMERCE_HEADING_CITY_DESC</option>
            <option value="c.country_name ASC">COM_J2COMMERCE_HEADING_COUNTRY_ASC</option>
            <option value="c.country_name DESC">COM_J2COMMERCE_HEADING_COUNTRY_DESC</option>
            <option value="z.zone_name ASC">COM_J2COMMERCE_HEADING_ZONE_ASC</option>
            <option value="z.zone_name DESC">COM_J2COMMERCE_HEADING_ZONE_DESC</option>
            <option value="a.j2commerce_manufacturer_id ASC">JGRID_HEADING_ID_ASC</option>
            <option value="a.j2commerce_manufacturer_id DESC">JGRID_HEADING_ID_DESC</option>
        </field>

        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>
