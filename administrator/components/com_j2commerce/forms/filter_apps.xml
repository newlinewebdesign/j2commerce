<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="COM_J2COMMERCE_FILTER_SEARCH_APPS_LABEL"
            description="COM_J2COMMERCE_FILTER_SEARCH_APPS_DESC"
            hint="JSEARCH_FILTER"
        />

        <field
            name="enabled"
            type="pluginstatus"
            label="JOPTION_SELECT_PUBLISHED"
            optionsFilter="*,0,1"
            onchange="this.form.submit();"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            onchange="this.form.submit();"
            default="a.name ASC"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.ordering ASC">COM_J2COMMERCE_HEADING_ORDERING_ASC</option>
            <option value="a.ordering DESC">COM_J2COMMERCE_HEADING_ORDERING_DESC</option>
            <option value="a.enabled ASC">COM_J2COMMERCE_HEADING_STATUS_ASC</option>
            <option value="a.enabled DESC">COM_J2COMMERCE_HEADING_STATUS_DESC</option>
            <option value="a.name ASC">COM_J2COMMERCE_APP_NAME_ASC</option>
            <option value="a.name DESC">COM_J2COMMERCE_APP_NAME_DESC</option>
            <option value="a.extension_id ASC">COM_J2COMMERCE_HEADING_ID_ASC</option>
            <option value="a.extension_id DESC">COM_J2COMMERCE_HEADING_ID_DESC</option>
        </field>

        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            onchange="this.form.submit();"
        />
    </fields>
</form>
