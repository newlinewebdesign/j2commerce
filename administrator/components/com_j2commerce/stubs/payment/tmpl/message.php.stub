defined('_JEXEC') or die;

use Joomla\CMS\Language\Text;

/** @var array $displayData */
$vars = $displayData['vars'];
?>

<?php if (!empty($vars->message)): ?>
    <div class="alert alert-<?php echo !empty($vars->error) ? 'danger' : 'info'; ?> j2commerce-payment-message">
        <?php echo htmlspecialchars(Text::_($vars->message), ENT_QUOTES, 'UTF-8'); ?>
    </div>
<?php endif; ?>
