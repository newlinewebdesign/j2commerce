<div id="{{name}}-error-message" class="alert alert-danger d-none" role="alert"></div>
<div id="{{name}}-processing-message" class="alert alert-info d-none" role="alert">
    <?php echo Text::_('PLG_J2COMMERCE_PAYMENT_{{NAME}}_PROCESSING'); ?>
</div>
