    <description>PLG_USER_J2COMMERCE_DESC</description>

    <namespace path="src">J2Commerce\Plugin\User\J2Commerce</namespace>

    <files>
        <folder plugin="j2commerce">services</folder>
        <folder>src</folder>
        <folder>language</folder>
    </files>

    <languages>
