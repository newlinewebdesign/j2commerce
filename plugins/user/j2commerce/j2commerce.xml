<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="user" method="upgrade">
    <name>PLG_USER_J2COMMERCE</name>
    <author>J2Commerce, LLC</author>
    <creationDate>2026-02</creationDate>
    <copyright>(C)2024-2026 J2Commerce, LLC. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <authorEmail>support@j2commerce.com</authorEmail>
    <authorUrl>https://www.j2commerce.com</authorUrl>
    <version>6.0.7</version>
    <description>PLG_USER_J2COMMERCE_DESC</description>

    <namespace path="src">J2Commerce\Plugin\User\J2Commerce</namespace>

    <files>
        <folder plugin="j2commerce">services</folder>
        <folder>src</folder>
        <folder>language</folder>
    </files>

    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="show_address_fields"
                    type="radio"
                    default="1"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    label="PLG_USER_J2COMMERCE_SHOW_ADDRESS_FIELDS"
                    description="PLG_USER_J2COMMERCE_SHOW_ADDRESS_FIELDS_DESC"
                >
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>
                <field
                    name="field_html"
                    type="textarea"
                    filter="safehtml"
                    rows="8"
                    label="PLG_USER_J2COMMERCE_FIELDS_HTML"
                    description="PLG_USER_J2COMMERCE_FIELDS_HTML_DESC"
                />
                <field
                    name="disable_name"
                    type="radio"
                    default="0"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    label="PLG_USER_J2COMMERCE_DISABLE_NAME"
                    description="PLG_USER_J2COMMERCE_DISABLE_NAME_DESC"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>
