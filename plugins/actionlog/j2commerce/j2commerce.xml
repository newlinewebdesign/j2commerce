        <language tag="zh-TW">zh-TW/plg_actionlog_j2commerce.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="notification_level"
                    type="list"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_NOTIFICATION_LEVEL"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_NOTIFICATION_LEVEL_DESC"
                    default="4"
                >
                    <option value="1">PLG_ACTIONLOG_J2COMMERCE_PRIORITY_BROWSE</option>
                    <option value="2">PLG_ACTIONLOG_J2COMMERCE_PRIORITY_ACTION</option>
                    <option value="3">PLG_ACTIONLOG_J2COMMERCE_PRIORITY_SUCCESS</option>
                    <option value="4">PLG_ACTIONLOG_J2COMMERCE_PRIORITY_WARNING</option>
                    <option value="5">PLG_ACTIONLOG_J2COMMERCE_PRIORITY_CRITICAL</option>
                </field>
                <field
                    name="notification_usergroups"
                    type="usergrouplist"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_NOTIFICATION_GROUPS"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_NOTIFICATION_GROUPS_DESC"
                    multiple="true"
                    layout="joomla.form.field.list-fancy-select"
                />
                <field
                    name="log_cart_events"
                    type="radio"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_CART"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_CART_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="log_checkout_events"
                    type="radio"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_CHECKOUT"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_CHECKOUT_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="log_order_events"
                    type="radio"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ORDERS"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ORDERS_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
            <fieldset name="admin" label="PLG_ACTIONLOG_J2COMMERCE_FIELDSET_ADMIN">
                <field
                    name="log_admin_products"
                    type="radio"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_PRODUCTS"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_PRODUCTS_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="log_admin_orders"
                    type="radio"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_ORDERS"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_ORDERS_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="log_admin_coupons"
                    type="radio"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_COUPONS"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_COUPONS_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="log_admin_tax"
                    type="radio"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_TAX"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_TAX_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="log_admin_shipping"
                    type="radio"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_SHIPPING"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_SHIPPING_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="log_admin_payment"
                    type="radio"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_PAYMENT"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_PAYMENT_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="log_admin_customers"
                    type="radio"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_CUSTOMERS"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_CUSTOMERS_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="log_admin_configuration"
                    type="radio"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_CONFIGURATION"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_CONFIGURATION_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="log_admin_catalog"
                    type="radio"
                    label="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_CATALOG"
                    description="PLG_ACTIONLOG_J2COMMERCE_PARAM_LOG_ADMIN_CATALOG_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>
