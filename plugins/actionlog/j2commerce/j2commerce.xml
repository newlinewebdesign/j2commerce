        <language tag="ar-AA">ar-AA/plg_actionlog_j2commerce.sys.ini</language>
        <language tag="da-DK">da-DK/plg_actionlog_j2commerce.ini</language>
        <language tag="da-DK">da-DK/plg_actionlog_j2commerce.sys.ini</language>
        <language tag="de-DE">de-DE/plg_actionlog_j2commerce.ini</language>
        <language tag="de-DE">de-DE/plg_actionlog_j2commerce.sys.ini</language>
        <language tag="el-GR">el-GR/plg_actionlog_j2commerce.ini</language>
        <language tag="el-GR">el-GR/plg_actionlog_j2commerce.sys.ini</language>
        <language tag="es-ES">es-ES/plg_actionlog_j2commerce.ini</language>
        <language tag="es-ES">es-ES/plg_actionlog_j2commerce.sys.ini</language>
        <language tag="fi-FI">fi-FI/plg_actionlog_j2commerce.ini</language>
