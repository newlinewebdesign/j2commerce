        <language tag="pt-PT">pt-PT/plg_actionlog_j2commerce.ini</language>
        <language tag="pt-PT">pt-PT/plg_actionlog_j2commerce.sys.ini</language>
        <language tag="ru-RU">ru-RU/plg_actionlog_j2commerce.ini</language>
