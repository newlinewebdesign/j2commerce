        <language tag="fr-FR">fr-FR/plg_actionlog_j2commerce.sys.ini</language>
        <language tag="he-IL">he-IL/plg_actionlog_j2commerce.ini</language>
        <language tag="he-IL">he-IL/plg_actionlog_j2commerce.sys.ini</language>
        <language tag="it-IT">it-IT/plg_actionlog_j2commerce.ini</language>
        <language tag="it-IT">it-IT/plg_actionlog_j2commerce.sys.ini</language>
        <language tag="ja-JP">ja-JP/plg_actionlog_j2commerce.ini</language>
        <language tag="ja-JP">ja-JP/plg_actionlog_j2commerce.sys.ini</language>
        <language tag="nb-NO">nb-NO/plg_actionlog_j2commerce.ini</language>
        <language tag="nb-NO">nb-NO/plg_actionlog_j2commerce.sys.ini</language>
        <language tag="nl-NL">nl-NL/plg_actionlog_j2commerce.ini</language>
        <language tag="nl-NL">nl-NL/plg_actionlog_j2commerce.sys.ini</language>
        <language tag="pl-PL">pl-PL/plg_actionlog_j2commerce.ini</language>
