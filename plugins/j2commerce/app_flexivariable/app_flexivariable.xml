            <fieldset name="basic">
                <field
                    name="option_required"
                    type="radio"
                    label="PLG_J2COMMERCE_APP_FLEXIVARIABLE_OPTION_REQUIRED"
                    description="PLG_J2COMMERCE_APP_FLEXIVARIABLE_OPTION_REQUIRED_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="0"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_price_range"
                    type="radio"
                    label="PLG_J2COMMERCE_APP_FLEXIVARIABLE_SHOW_PRICE_RANGE"
                    description="PLG_J2COMMERCE_APP_FLEXIVARIABLE_SHOW_PRICE_RANGE_DESC"
