        <language tag="zh-TW">zh-TW/plg_j2commerce_payment_paypal.ini</language>
        <language tag="zh-TW">zh-TW/plg_j2commerce_payment_paypal.sys.ini</language>
    </languages>

    <media folder="media" destination="plg_j2commerce_payment_paypal">
        <folder>images</folder>
        <folder>js</folder>
    </media>

    <config>
        <fields name="params">
            <fieldset name="basic" label="PLG_J2COMMERCE_PAYMENT_PAYPAL">
                <field
                    name="payment_method_type"
                    type="hidden"
                    default="PLG_J2COMMERCE_PAYMENT_METHOD"
                />
                <field
                    name="display_name"
                    type="text"
                    label="COM_J2COMMERCE_PLUGIN_DISPLAY_NAME"
                    description="COM_J2COMMERCE_PLUGIN_DISPLAY_NAME_DESC"
                    default="PLG_J2COMMERCE_PAYMENT_PAYPAL"
                />
                <field
                    name="display_image"
                    type="media"
                    label="COM_J2COMMERCE_PLUGIN_DISPLAY_IMAGE"
                    description="COM_J2COMMERCE_PLUGIN_DISPLAY_IMAGE_DESC"
                />

                <field
                    name="sandbox"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    default="0"
                    label="PLG_J2COMMERCE_PAYMENT_PAYPAL_USE_SANDBOX"
                    description="PLG_J2COMMERCE_PAYMENT_PAYPAL_USE_SANDBOX_DESC"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field type="spacer" />

                <field
                    name="client_id"
                    type="text"
                    size="70"
                    label="PLG_J2COMMERCE_PAYMENT_PAYPAL_CLIENT_ID"
                    description="PLG_J2COMMERCE_PAYMENT_PAYPAL_CLIENT_ID_DESC"
                />
                <field
                    name="client_secret"
                    type="text"
                    size="70"
                    label="PLG_J2COMMERCE_PAYMENT_PAYPAL_CLIENT_SECRET"
                    description="PLG_J2COMMERCE_PAYMENT_PAYPAL_CLIENT_SECRET_DESC"
                />

                <field type="spacer" />

                <field
                    name="sandbox_client_id"
                    type="text"
                    size="70"
                    label="PLG_J2COMMERCE_PAYMENT_PAYPAL_SANDBOX_CLIENT_ID"
                    description="PLG_J2COMMERCE_PAYMENT_PAYPAL_SANDBOX_CLIENT_ID_DESC"
                />
                <field
                    name="sandbox_client_secret"
                    type="text"
                    size="70"
                    label="PLG_J2COMMERCE_PAYMENT_PAYPAL_SANDBOX_CLIENT_SECRET"
                    description="PLG_J2COMMERCE_PAYMENT_PAYPAL_SANDBOX_CLIENT_SECRET_DESC"
                />

                <field type="spacer" />

                <field
                    name="webhook_id"
                    type="text"
                    size="70"
                    label="PLG_J2COMMERCE_PAYMENT_PAYPAL_WEBHOOK_ID"
                    description="PLG_J2COMMERCE_PAYMENT_PAYPAL_WEBHOOK_ID_DESC"
                />
                <field
                    name="sandbox_webhook_id"
                    type="text"
                    size="70"
                    label="PLG_J2COMMERCE_PAYMENT_PAYPAL_SANDBOX_WEBHOOK_ID"
                    description="PLG_J2COMMERCE_PAYMENT_PAYPAL_SANDBOX_WEBHOOK_ID_DESC"
                />

                <field type="spacer" />

                <field
                    name="payment_status"
                    type="OrderStatus"
                    label="PLG_J2COMMERCE_ORDER_STATUS"
                    description="PLG_J2COMMERCE_ORDER_STATUS_DESC"
                    default="1"
                    addfieldprefix="J2Commerce\Component\J2commerce\Administrator\Field"
                    layout="joomla.form.field.list-fancy-select"
                />

                <field type="spacer" />

                <field
                    name="surcharge_name"
                    type="text"
                    default=""
                    label="COM_J2COMMERCE_PLUGIN_SURCHARGE_NAME"
                    description="COM_J2COMMERCE_PLUGIN_SURCHARGE_NAME_DESC"
                />

                <field
                    name="surcharge_percent"
                    type="text"
                    default=""
                    label="COM_J2COMMERCE_PLUGIN_SURCHARGE_PERCENT"
                    description="COM_J2COMMERCE_PLUGIN_SURCHARGE_PERCENT_DESC"
                />

                <field
                    name="surcharge_fixed"
                    type="text"
                    default=""
                    label="COM_J2COMMERCE_PLUGIN_SURCHARGE_FIXED"
                    description="COM_J2COMMERCE_PLUGIN_SURCHARGE_FIXED_DESC"
                />

                <field
                    name="surcharge_tax_class_id"
                    type="TaxProfile"
                    default=""
                    label="COM_J2COMMERCE_PLUGIN_SURCHARGE_TAX_CLASS"
                    description="COM_J2COMMERCE_PLUGIN_SURCHARGE_TAX_CLASS_DESC"
                    addfieldpath="J2Commerce\Component\J2commerce\Administrator\Field"
                />

                <field type="spacer" />

                <field
                    name="geozone_id"
                    type="GeoZone"
                    default=""
                    label="COM_J2COMMERCE_GEOZONE_RESTRICTION"
                    description="COM_J2COMMERCE_GEOZONE_RESTRICTION_DESC"
                    addfieldprefix="J2Commerce\Component\J2commerce\Administrator\Field"
                    layout="joomla.form.field.list-fancy-select"
                />

                <field
                    name="min_subtotal"
                    type="text"
                    default=""
                    label="COM_J2COMMERCE_PLUGIN_MIN_SUBTOTAL"
                    description="COM_J2COMMERCE_PLUGIN_MIN_SUBTOTAL_DESC"
                />

                <field
                    name="max_subtotal"
                    type="text"
                    default=""
                    label="COM_J2COMMERCE_PLUGIN_MAX_SUBTOTAL"
                    description="COM_J2COMMERCE_PLUGIN_MAX_SUBTOTAL_DESC"
                />

                <field type="spacer" />

                <field
                    name="articleid"
                    type="modal_article"
                    label="COM_J2COMMERCE_THANKS_MSG"
                    description="COM_J2COMMERCE_THANKS_MSG_DESC"
                    select="true"
                    new="false"
                    edit="false"
                    clear="true"
                    addfieldprefix="Joomla\Component\Content\Administrator\Field"
                />

                <field type="spacer" />

                <field
                    name="onselection"
                    type="textarea"
                    cols="10"
                    rows="3"
                    default=""
                    label="COM_J2COMMERCE_ON_SELECTION_LABEL"
                    description="COM_J2COMMERCE_ON_SELECTION_DESC"
                />
                <field
                    name="onbeforepayment"
                    type="textarea"
                    cols="10"
                    rows="3"
                    default=""
                    label="COM_J2COMMERCE_ON_BEFORE_PAYMENT_LABEL"
                    description="COM_J2COMMERCE_ON_BEFORE_PAYMENT_DESC"
                />
                <field
                    name="onafterpayment"
                    type="textarea"
                    cols="10"
                    rows="3"
                    default=""
                    label="COM_J2COMMERCE_ON_AFTER_PAYMENT_LABEL"
                    description="COM_J2COMMERCE_ON_AFTER_PAYMENT_DESC"
                />
                <field
                    name="onerrorpayment"
                    type="textarea"
                    cols="10"
                    rows="3"
                    default=""
                    label="COM_J2COMMERCE_ON_ERROR_PAYMENT_LABEL"
                    description="COM_J2COMMERCE_ON_ERROR_PAYMENT_DESC"
                />
                <field
                    name="oncancelpayment"
                    type="textarea"
                    cols="10"
                    rows="3"
                    default=""
                    label="COM_J2COMMERCE_ON_CANCEL_PAYMENT_LABEL"
                    description="COM_J2COMMERCE_ON_CANCEL_PAYMENT_DESC"
                />

                <field type="spacer" />

                <field
                    name="show_dashboard_icon"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="0"
                    label="COM_J2COMMERCE_PLUGIN_SHOW_DASHBOARD_ICON"
                    description="COM_J2COMMERCE_PLUGIN_SHOW_DASHBOARD_ICON_DESC"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field
                    name="dashboard_icon_label"
                    type="text"
                    filter="string"
                    default=""
                    label="COM_J2COMMERCE_PLUGIN_DASHBOARD_ICON_LABEL"
                    description="COM_J2COMMERCE_PLUGIN_DASHBOARD_ICON_LABEL_DESC"
                    showon="show_dashboard_icon:1"
                />

                <field type="spacer" />

                <field
                    name="subtemplate"
                    type="PluginSubtemplate"
                    plugin_group="j2commerce"
                    plugin_element="payment_paypal"
                    label="COM_J2COMMERCE_PLUGIN_SUBTEMPLATE"
                    description="COM_J2COMMERCE_PLUGIN_SUBTEMPLATE_DESC"
                    default=""
                    addfieldprefix="J2Commerce\Component\J2commerce\Administrator\Field"
                />

                <field type="spacer" />

                <field
                    name="debug"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_J2COMMERCE_PAYMENT_PAYPAL_DEBUG_LABEL"
                    description="PLG_J2COMMERCE_PAYMENT_PAYPAL_DEBUG_DESC"
                    filter="integer"
                    default="0"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
        </fields>
    </config>


</extension>
