        <language tag="it-IT">it-IT/plg_j2commerce_payment_paypal.ini</language>
        <language tag="it-IT">it-IT/plg_j2commerce_payment_paypal.sys.ini</language>
        <language tag="ja-JP">ja-JP/plg_j2commerce_payment_paypal.ini</language>
        <language tag="ja-JP">ja-JP/plg_j2commerce_payment_paypal.sys.ini</language>
        <language tag="nb-NO">nb-NO/plg_j2commerce_payment_paypal.ini</language>
        <language tag="nb-NO">nb-NO/plg_j2commerce_payment_paypal.sys.ini</language>
        <language tag="nl-NL">nl-NL/plg_j2commerce_payment_paypal.ini</language>
        <language tag="nl-NL">nl-NL/plg_j2commerce_payment_paypal.sys.ini</language>
        <language tag="pl-PL">pl-PL/plg_j2commerce_payment_paypal.ini</language>
        <language tag="pl-PL">pl-PL/plg_j2commerce_payment_paypal.sys.ini</language>
        <language tag="pt-PT">pt-PT/plg_j2commerce_payment_paypal.ini</language>
