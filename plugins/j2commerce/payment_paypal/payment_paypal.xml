    <description>PLG_J2COMMERCE_PAYMENT_PAYPAL_DESC</description>
    <namespace path="src">J2Commerce\Plugin\J2Commerce\PaymentPaypal</namespace>

    <files>
        <folder plugin="payment_paypal">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>

    <languages folder="language">
        <language tag="en-US">en-US/plg_j2commerce_payment_paypal.ini</language>
        <language tag="en-US">en-US/plg_j2commerce_payment_paypal.sys.ini</language>
        <language tag="en-GB">en-GB/plg_j2commerce_payment_paypal.ini</language>
