    <namespace path="src">J2Commerce\Plugin\J2Commerce\PaymentCash</namespace>

    <files>
        <folder plugin="payment_cash">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>

    <languages folder="language">
        <language tag="en-US">en-US/plg_j2commerce_payment_cash.ini</language>
