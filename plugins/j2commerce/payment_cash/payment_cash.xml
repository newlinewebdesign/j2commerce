        <language tag="pl-PL">pl-PL/plg_j2commerce_payment_cash.ini</language>
        <language tag="pl-PL">pl-PL/plg_j2commerce_payment_cash.sys.ini</language>
        <language tag="sv-SE">sv-SE/plg_j2commerce_payment_cash.ini</language>
        <language tag="sv-SE">sv-SE/plg_j2commerce_payment_cash.sys.ini</language>
        <language tag="nb-NO">nb-NO/plg_j2commerce_payment_cash.ini</language>
        <language tag="nb-NO">nb-NO/plg_j2commerce_payment_cash.sys.ini</language>
