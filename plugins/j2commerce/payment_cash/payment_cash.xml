        <language tag="el-GR">el-GR/plg_j2commerce_payment_cash.sys.ini</language>
        <language tag="he-IL">he-IL/plg_j2commerce_payment_cash.ini</language>
        <language tag="he-IL">he-IL/plg_j2commerce_payment_cash.sys.ini</language>
        <language tag="ar-AA">ar-AA/plg_j2commerce_payment_cash.ini</language>
